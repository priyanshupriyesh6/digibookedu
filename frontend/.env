# Auth0 Domain for authentication setup
VITE_AUTH0_DOMAIN=your_auth0_domain_here

# Auth0 Client ID for authentication setup
VITE_AUTH0_CLIENT_ID=your_auth0_client_id_here

# Live hosted Express REST API base URL (your backend on Render/Railway etc.)
# IMPORTANT: This MUST point to your backend server, NOT the Vercel frontend URL
# Example: https://digibookedu-backend.onrender.com
# Leave empty to use the dynamic localhost:5000 fallback (for local dev only)
VITE_API_BASE=

# Clerk publishable key (safe to use in frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsuZGlnaWJvb2tlZHUuaW4k
