# Auth0 Domain for authentication setup
VITE_AUTH0_DOMAIN=your_auth0_domain_here

# Auth0 Client ID for authentication setup
VITE_AUTH0_CLIENT_ID=your_auth0_client_id_here

# Live hosted Express REST API base URL (e.g. on Render or Railway). Leave blank for local fallback.
VITE_API_BASE=your_backend_api_url_here
